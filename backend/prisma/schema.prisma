datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum ProjectStatus {
  Pending
  Under_Review  @map("Under Review")
  Planning
  Designing
  Development
  Testing
  Completed
  Cancelled
}

enum ContactStatus {
  New
  Read
  Replied
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  avatar        String?
  phone         String?
  role          Role           @default(USER)
  emailVerified Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  projects      Project[]      @relation("ClientProjects")
  conversationsAsClient ChatConversation[] @relation("ConversationClient")
  conversationsAsAdmin  ChatConversation[] @relation("ConversationAdmin")
  sentMessages  ChatMessage[]  @relation("SentMessages")
  notifications Notification[]
  reviews       Review[]
  activityLogs  ActivityLog[]
}

model Project {
  id              String         @id @default(uuid())
  clientId        String
  title           String
  description     String
  industry        String?
  budget          String
  timeline        String
  preferredColors String?
  references      String?
  aiSummary       String?
  status          ProjectStatus  @default(Pending)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  client          User           @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  files           ProjectFile[]
  conversations   ChatConversation[]

  @@index([clientId])
}

model ProjectFile {
  id         String   @id @default(uuid())
  projectId  String
  filename   String
  url        String
  size       String
  uploadedAt DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ChatConversation {
  id        String   @id @default(uuid())
  projectId String?
  clientId  String
  adminId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client       User          @relation("ConversationClient", fields: [clientId], references: [id], onDelete: Cascade)
  admin        User          @relation("ConversationAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@unique([clientId, adminId, projectId])
  @@index([clientId])
  @@index([adminId])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  receiverId     String?
  senderRole     Role?
  content        String?          @default("")
  message        String?          @default("") // for backward compatibility
  attachment     String?          // for backward compatibility
  attachmentUrl  String?
  seen           Boolean          @default(false)
  delivered      Boolean          @default(false)
  createdAt      DateTime         @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  rating    Int
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([approved])
}

model Service {
  id            String @id @default(uuid())
  title         String
  description   String
  startingPrice Int
  icon          String
}

model Portfolio {
  id           String   @id @default(uuid())
  title        String
  description  String
  coverImage   String
  gallery      String[] // array of URLs
  technologies String[]
  category     String
}

model Blog {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  content    String
  coverImage String
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ContactRequest {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(New)
  createdAt DateTime      @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}
